{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total[1m])) by (status_class)",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "title": "In-Flight Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(gateway_inflight_requests) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Request Duration (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(gateway_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total{status_class=\"5xx\"}[5m])) / sum(rate(gateway_http_requests_total[5m]))",
          "legendFormat": "5xx rate"
        }
      ]
    },
    {
      "title": "Config Reloads",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(gateway_config_reload_total{result=\"success\"}) or vector(0)",
          "legendFormat": "success"
        },
        {
          "expr": "sum(gateway_config_reload_total{result=\"validation_error\"}) or vector(0)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Rate Limiting",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_rate_limit_allowed_total[1m]))",
          "legendFormat": "allowed"
        },
        {
          "expr": "sum(rate(gateway_rate_limit_denied_total[1m]))",
          "legendFormat": "denied"
        },
        {
          "expr": "sum(rate(gateway_rate_limit_degraded_total[1m]))",
          "legendFormat": "degraded"
        }
      ]
    },
    {
      "title": "Auth Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_auth_failures_total[1m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "title": "Upstream Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_upstream_failures_total[1m])) by (service, reason)",
          "legendFormat": "{{service}} - {{reason}}"
        }
      ]
    },
    {
      "title": "Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total[1m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["api-gateway"],
